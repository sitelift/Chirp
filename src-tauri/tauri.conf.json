{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chirp",
  "version": "1.0.0",
  "identifier": "com.chirp.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "Chirp",
        "width": 340,
        "height": 120,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false
      },
      {
        "label": "settings",
        "title": "Chirp Settings",
        "width": 640,
        "height": 520,
        "resizable": true,
        "minWidth": 560,
        "minHeight": 440,
        "decorations": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
