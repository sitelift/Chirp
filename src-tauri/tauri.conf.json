{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chirp",
  "version": "1.2.4",
  "identifier": "com.chirp.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "Chirp",
        "width": 300,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": false,
        "focus": false
      },
      {
        "label": "settings",
        "title": "Chirp",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "visible": false,
        "center": true,
        "maximized": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://huggingface.co https://*.huggingface.co https://github.com https://objects.githubusercontent.com https://*.ingest.sentry.io"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sitelift/Chirp/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJBN0NGMzkxQ0YxQjE3QzAKUldUQUZ4dlBrZk44dWd5VjVxc0ZBa2FRalY2b04yV0xROHRwL0FKSTBpMjJqNkZObkt5bEpiNG0K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "signCommand": "trusted-signing-cli -e https://eus.codesigning.azure.net -a chirp -c chirp-codesigning -d Chirp %1",
      "nsis": {
        "headerImage": "installer/chirp-header.bmp",
        "sidebarImage": "installer/chirp-sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "compression": "lzma"
      }
    },
    "macOS": {
      "entitlements": "entitlements.plist",
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0",
      "infoPlist": "Info.plist"
    }
  }
}
